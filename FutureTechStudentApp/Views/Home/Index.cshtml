@{
    Layout = null;
    ViewData["Title"] = "FutureTech Academy | Home";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: linear-gradient(rgba(10, 15, 30, 0.8), rgba(10, 15, 30, 0.8)), url('https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&fit=crop&w=1920&q=80') no-repeat center center fixed; background-size: cover; color: #ffffff; overflow-x: hidden; }
        .glass-panel { background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.1); box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3); }
        .navbar-glass { background: rgba(10, 15, 30, 0.6) !important; backdrop-filter: blur(20px); border-bottom: 1px solid rgba(255, 255, 255, 0.05); }
        .nav-brand { font-weight: 800; font-size: 1.5rem; letter-spacing: 1px; }
        .hero-section { padding: 120px 0 80px; min-height: 70vh; display: flex; align-items: center; }
        .hero-title { font-weight: 800; background: -webkit-linear-gradient(45deg, #0dcaf0, #ffffff); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 20px; }
        .btn-main { border-radius: 50px; padding: 12px 35px; font-weight: 600; transition: all 0.3s ease; }
        .btn-info { background-color: #0dcaf0; border: none; color: #000; box-shadow: 0 0 15px rgba(13, 202, 240, 0.4); }
        .btn-info:hover { background-color: #ffffff; transform: translateY(-2px); }
        .feature-card { border-radius: 20px; padding: 40px 30px; height: 100%; transition: all 0.4s; }
        .feature-card:hover { transform: translateY(-15px); background: rgba(255, 255, 255, 0.08); }
        .icon-box { width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; background: rgba(13, 202, 240, 0.1); border: 1px solid rgba(13, 202, 240, 0.3); }
        .stats-ribbon { border-top: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1); background: rgba(0,0,0,0.3); }
        footer { background: rgba(0, 0, 0, 0.8); border-top: 1px solid rgba(255, 255, 255, 0.05); padding: 30px 0; backdrop-filter: blur(10px); }
        .animate-up { opacity: 0; animation: slideUpFade 0.8s forwards; }
        @@keyframes slideUpFade { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark navbar-glass sticky-top py-3">
        <div class="container">
            <a class="navbar-brand nav-brand text-white" href="#">
                <i class="bi bi-hexagon-fill text-info me-2"></i> FUTURETECH
            </a>
            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                <div class="d-flex align-items-center">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <span class="text-light me-4"><i class="bi bi-person-circle me-1"></i> Hello, <strong>@(User.Identity?.Name ?? "Admin")</strong></span>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                            <button type="submit" class="btn btn-outline-light btn-sm rounded-pill px-4">Log Out</button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-info btn-sm rounded-pill px-4 fw-bold">Admin Login</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <header class="hero-section text-center">
        <div class="container">
            <div class="col-lg-8 mx-auto animate-up">
                <h1 class="display-3 hero-title">Student Management Reimagined</h1>
                <p class="lead mb-5 opacity-75">Secure administrative portal for cloud-based student records.</p>
                <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="Student" asp-action="Index" class="btn btn-info btn-lg btn-main"><i class="bi bi-person-lines-fill me-2"></i> Dashboard</a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-info btn-lg btn-main"><i class="bi bi-shield-lock-fill me-2"></i> Login (Google / GitHub)</a>
                    }
                </div>
            </div>
        </div>
    </header>

    <section class="container my-5 py-5 text-center">
        <div class="row g-4">
            <div class="col-md-4"><div class="glass-panel feature-card"><div class="icon-box text-info display-6"><i class="bi bi-database-fill-zap"></i></div><h5>NoSQL Database</h5><p class="small opacity-75">Powered by Azure Cosmos DB.</p></div></div>
            <div class="col-md-4"><div class="glass-panel feature-card"><div class="icon-box text-info display-6"><i class="bi bi-cloud-arrow-up-fill"></i></div><h5>Blob Storage</h5><p class="small opacity-75">Secure image handling via SAS.</p></div></div>
            <div class="col-md-4"><div class="glass-panel feature-card"><div class="icon-box text-info display-6"><i class="bi bi-github"></i></div><h5>OAuth 2.0</h5><p class="small opacity-75">Secure Google/GitHub Auth.</p></div></div>
        </div>
    </section>

    <footer>
        <div class="container text-center text-md-start">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <p class="mb-0 fw-bold"><i class="bi bi-hexagon-fill text-info me-1"></i> FUTURETECH ACADEMY</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <a asp-controller="Home" asp-action="Privacy" class="text-info text-decoration-none small me-4">Privacy Policy</a>
                    <a asp-controller="Home" asp-action="Terms" class="text-light opacity-75 text-decoration-none small">Terms of Service</a>
                </div>
            </div>
        </div>
    </footer>
</body>
</html>