@{
    Layout = null;
    ViewData["Title"] = "Admin Secure Login | FutureTech";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(rgba(255, 255, 255, 0.6), rgba(255, 255, 255, 0.6)), url('https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=1920&q=80') no-repeat center center fixed;
            background-size: cover;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            padding: 20px;
        }

        .login-card {
            width: 100%;
            max-width: 450px;
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(20px);
            border-radius: 28px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.1);
            padding: 45px;
            animation: fadeInUp 0.5s ease-out;
        }

        .login-icon-circle {
            width: 70px;
            height: 70px;
            background: #0d6efd;
            color: white;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.2rem;
            margin: 0 auto 20px;
            box-shadow: 0 10px 20px rgba(13, 110, 253, 0.2);
        }

        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>

    <div class="login-card">
        <div class="text-center mb-4">
            <div class="login-icon-circle"><i class="bi bi-shield-lock-fill"></i></div>
            <h3 class="fw-bold text-dark mb-1">Admin Secure Sign-In</h3>
            <!-- Updated description -->
            <p class="text-muted small">Use your authorized account to access the dashboard.</p>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger rounded-3 small p-3 text-center">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            </div>
        }

        <!-- Google Login Form (Using the new generic action) -->
        <form asp-controller="Account" asp-action="ExternalLogin" asp-route-provider="Google" method="post" class="mt-4 d-grid">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger w-100 py-3 fw-bold rounded-3 shadow-sm mb-3">
                <i class="bi bi-google me-2"></i> Sign In with Google
            </button>
        </form>

        <!-- GitHub Login Form (Using the new generic action) -->
        <form asp-controller="Account" asp-action="ExternalLogin" asp-route-provider="GitHub" method="post" class="d-grid">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-dark w-100 py-3 fw-bold rounded-3 shadow-sm">
                <i class="bi bi-github me-2"></i> Sign In with GitHub
            </button>
        </form>

        <div class="text-center mt-4">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none fw-bold small text-secondary">
                <i class="bi bi-arrow-left-short"></i> Back to Homepage
            </a>
        </div>
    </div>

</body>
</html>