@model FutureTechStudentApp.Models.StaffMember

@{
    Layout = null;
    ViewData["Title"] = "Staff Registration | FutureTech";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(rgba(255, 255, 255, 0.75), rgba(255, 255, 255, 0.75)), url('https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=1920&q=80') no-repeat center center fixed;
            background-size: cover;
            min-height: 100vh;
            padding: 40px 20px;
            display: flex;
            align-items: center;
        }

        .register-card {
            max-width: 650px;
            width: 100%;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(25px);
            border-radius: 24px;
            box-shadow: 0 24px 80px rgba(0,0,0,0.08), 0 0 0 1px rgba(255,255,255,0.5) inset;
            padding: 40px 50px;
            animation: fadeInUp 0.6s ease-out;
            position: relative;
        }

        .btn-back {
            position: absolute;
            top: 25px;
            left: 25px;
            color: #6c757d;
            font-size: 0.9rem;
            font-weight: 500;
            text-decoration: none;
            transition: color 0.2s;
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .btn-back:hover {
                color: #0d6efd;
            }

        .logo-box {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #0d6efd, #0b5ed7);
            color: white;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            margin: 0 auto 20px;
            box-shadow: 0 10px 20px rgba(13, 110, 253, 0.25);
        }

        .form-label {
            font-weight: 600;
            font-size: 0.8rem;
            color: #495057;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
        }

        /* Unified Input Styling */
        .input-group {
            box-shadow: 0 2px 5px rgba(0,0,0,0.02);
            border-radius: 12px;
            transition: all 0.3s ease;
        }

            .input-group:focus-within {
                box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.15);
            }

        .input-group-text {
            background-color: #f8f9fa;
            border-right: none;
            color: #0d6efd;
            border-radius: 12px 0 0 12px;
            border-color: #dee2e6;
        }

        .form-control, .form-select {
            border-left: none;
            border-radius: 0 12px 12px 0;
            padding: 12px 15px;
            font-size: 0.95rem;
            border-color: #dee2e6;
        }

            .form-control:focus, .form-select:focus {
                box-shadow: none;
                border-color: #dee2e6;
            }

        .input-group:focus-within .input-group-text,
        .input-group:focus-within .form-control,
        .input-group:focus-within .form-select,
        .input-group:focus-within .toggle-eye {
            border-color: #0d6efd;
        }

        /* Eye toggle add-on */
        .toggle-eye {
            background-color: #fff;
            border-left: none;
            border-radius: 0 12px 12px 0;
            cursor: pointer;
            color: #6c757d;
        }

        .btn-register {
            background: linear-gradient(135deg, #0d6efd, #0a58ca);
            border: none;
            padding: 15px;
            font-weight: 600;
            font-size: 1.05rem;
            border-radius: 12px;
            box-shadow: 0 8px 20px rgba(13, 110, 253, 0.2);
            transition: all 0.3s ease;
            margin-top: 10px;
        }

            .btn-register:hover {
                transform: translateY(-2px);
                box-shadow: 0 12px 25px rgba(13, 110, 253, 0.3);
            }

        .field-validation-error {
            color: #dc3545;
            font-size: 0.8rem;
            font-weight: 500;
            margin-top: 5px;
            display: block;
        }

        .login-link-container {
            margin-top: 25px;
            padding-top: 20px;
            border-top: 1px solid rgba(0,0,0,0.08);
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Mobile adjustments */
        @@media (max-width: 576px) {
            .register-card {
                padding: 40px 25px 25px;
            }

            .btn-back {
                top: 15px;
                left: 15px;
            }
        }
    </style>
</head>
<body>

    <div class="container d-flex justify-content-center">
        <div class="register-card">

            <!-- Back Button -->
            <a asp-controller="Home" asp-action="Index" class="btn-back">
                <i class="bi bi-arrow-left"></i> Back
            </a>

            <div class="text-center mb-4 mt-2">
                <div class="logo-box"><i class="bi bi-hexagon-fill"></i></div>
                <h3 class="fw-bold text-dark mb-2">Staff Access Portal</h3>
                <p class="text-muted small mb-0">Register to manage student records and cloud assets.</p>
            </div>

            <form asp-action="Register" method="post" id="regForm">
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger small p-3 rounded-3 mb-4 border-0" style="background-color: #fff5f5; color: #dc3545;">
                        <div asp-validation-summary="ModelOnly" class="mb-0 fw-medium"></div>
                    </div>
                }

                <div class="row">
                    <div class="col-12 mb-3">
                        <label class="form-label">Full Name</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person-vcard"></i></span>
                            <input asp-for="FullName" class="form-control" placeholder="Institutional Name" autocomplete="name" required>
                        </div>
                        <span asp-validation-for="FullName" class="field-validation-error"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Work Email</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope-at"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="name@futuretech.com" autocomplete="email" required>
                        </div>
                        <span asp-validation-for="Email" class="field-validation-error"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Confirm Email</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope-check"></i></span>
                            <input asp-for="ConfirmEmail" class="form-control" placeholder="Repeat email" required>
                        </div>
                        <span asp-validation-for="ConfirmEmail" class="field-validation-error"></span>
                    </div>

                    <div class="col-12 mb-3">
                        <label class="form-label">Department</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-building"></i></span>
                            <select asp-for="Department" class="form-select" required>
                                <option value="" disabled selected>Select Department...</option>
                                <option value="IT">Information Technology (Admin)</option>
                                <option value="Registrar">Registrar's Office</option>
                            </select>
                        </div>
                        <span asp-validation-for="Department" class="field-validation-error"></span>
                    </div>

                    <!-- Password Fields with Toggles -->
                    <div class="col-md-6 mb-4">
                        <label class="form-label">Password</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-key"></i></span>
                            <input asp-for="Password" type="password" id="pass1" class="form-control border-end-0" autocomplete="new-password" placeholder="Create password" required>
                            <span class="input-group-text toggle-eye" onclick="togglePass('pass1', 'icon1')">
                                <i class="bi bi-eye" id="icon1"></i>
                            </span>
                        </div>
                        <span asp-validation-for="Password" class="field-validation-error"></span>
                    </div>
                    <div class="col-md-6 mb-4">
                        <label class="form-label">Confirm Password</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-shield-lock"></i></span>
                            <input asp-for="ConfirmPassword" type="password" id="pass2" class="form-control border-end-0" autocomplete="new-password" placeholder="Repeat password" required>
                            <span class="input-group-text toggle-eye" onclick="togglePass('pass2', 'icon2')">
                                <i class="bi bi-eye" id="icon2"></i>
                            </span>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-register btn-primary w-100" id="submitBtn">
                    Register Account <i class="bi bi-arrow-right ms-1"></i>
                </button>
            </form>

            <!-- Already have an account -->
            <div class="text-center login-link-container">
                <p class="text-muted small mb-0">
                    Already have a staff account?
                    <a asp-controller="Account" asp-action="Login" class="text-primary fw-bold text-decoration-none ms-1">
                        Log in here
                    </a>
                </p>
            </div>

        </div>
    </div>

    <script>
        // Toggles password visibility and updates the icon
        function togglePass(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);

            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("bi-eye");
                icon.classList.add("bi-eye-slash");
            } else {
                input.type = "password";
                icon.classList.remove("bi-eye-slash");
                icon.classList.add("bi-eye");
            }
        }

        // Prevent multiple form submissions
        document.getElementById("regForm").onsubmit = function() {
            if($(this).valid()) {
                const btn = document.getElementById("submitBtn");
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> Processing...';
                btn.style.opacity = '0.8';
                btn.style.pointerEvents = 'none';
            }
        };
    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>l>