@model FutureTechStudentApp.Models.Student

@{
    Layout = null; // Independent page
    ViewData["Title"] = "Update Student | FutureTech";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <!-- Professional Assets -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(rgba(255, 255, 255, 0.75), rgba(255, 255, 255, 0.75)), url('https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=1920&q=80') no-repeat center center fixed;
            background-size: cover;
            color: #2d3436;
            min-height: 100vh;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.05);
            border-radius: 1.5rem;
            padding: 40px;
        }

        .navbar-glass {
            background: rgba(255, 255, 255, 0.8) !important;
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
            padding: 15px 0;
        }

        .profile-frame {
            position: relative;
            display: inline-block;
        }

        .profile-image {
            width: 160px;
            height: 160px;
            object-fit: cover;
            border-radius: 30px;
            border: 5px solid white;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

        .status-badge {
            position: absolute;
            bottom: -10px;
            right: -10px;
            background: #0d6efd;
            color: white;
            padding: 8px;
            border-radius: 12px;
            box-shadow: 0 4px 10px rgba(13, 110, 253, 0.3);
        }

        .form-label {
            font-weight: 700;
            font-size: 0.75rem;
            color: #495057;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .input-group-text {
            background: white;
            border-right: none;
            color: #0d6efd;
            border-radius: 12px 0 0 12px;
        }

        .form-control, .form-select {
            border-left: none;
            border-radius: 0 12px 12px 0;
            padding: 12px;
            border-color: #dee2e6;
        }

            .form-control:focus, .form-select:focus {
                box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.1);
                border-color: #dee2e6;
            }

        /* Validation Error Styling */
        .text-danger {
            font-size: 0.75rem;
            font-weight: 600;
            margin-top: 5px;
            display: block;
        }

        .glass-note {
            background: rgba(13, 110, 253, 0.05);
            border-radius: 15px;
            padding: 20px;
            border: 1px solid rgba(13, 110, 253, 0.1);
        }

        .btn-save {
            background: #0d6efd;
            border: none;
            padding: 12px 40px;
            font-weight: 700;
            border-radius: 50px;
            box-shadow: 0 8px 15px rgba(13, 110, 253, 0.2);
            transition: all 0.3s ease;
        }

            .btn-save:hover {
                background: #0b5ed7;
                transform: translateY(-2px);
            }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-light navbar-glass sticky-top mb-5">
        <div class="container">
            <a asp-action="Index" class="text-decoration-none fw-bold text-dark hover-blue">
                <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
            </a>
            <span class="navbar-brand ms-auto fw-bold text-primary">
                <i class="bi bi-pencil-square me-1"></i> UPDATE <span class="text-dark fw-light">Record</span>
            </span>
        </div>
    </nav>

    <main class="container mb-5">
        <div class="row justify-content-center">
            <div class="col-xl-10">

                <div class="glass-panel">
                    <form asp-action="Edit">
                        <!-- Essential Hidden Fields -->
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ProfileImageUrl" />

                        <div class="row g-5">
                            <!-- Left Side: Profile Identity -->
                            <div class="col-lg-4 text-center border-end border-opacity-10">
                                <h6 class="text-uppercase tracking-widest text-muted mb-4" style="font-size: 0.7rem;">Institutional Identity</h6>

                                <div class="profile-frame mb-4">
                                    <img src="@Model.ProfileImageUrl" class="profile-image"
                                         onerror="this.src='https://ui-avatars.com/api/?name=@Model.FirstName+@Model.LastName&background=0d6efd&color=fff'">
                                    <div class="status-badge" title="Cloud Verified">
                                        <i class="bi bi-cloud-check-fill"></i>
                                    </div>
                                </div>

                                <div class="glass-note text-start small">
                                    <p class="mb-0 text-muted">
                                        <i class="bi bi-info-circle-fill text-primary me-2"></i>
                                        <strong>Storage Notice:</strong> Images are linked via <strong>Azure Blob Storage</strong>. To update a photo, please purge and re-register the student.
                                    </p>
                                </div>
                            </div>

                            <!-- Right Side: Editable Details -->
                            <div class="col-lg-8 ps-lg-5">
                                <div class="mb-4">
                                    <h3 class="fw-bold mb-1">Modify Student Data</h3>
                                    <p class="text-muted small">Update contact information and enrollment standing.</p>
                                </div>

                                <div class="row g-4">
                                    <!-- REQUIRED VALIDATION SPANS ADDED FOR MARKS -->
                                    <div class="col-md-6">
                                        <label class="form-label">First Name</label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                                            <input asp-for="FirstName" class="form-control" required />
                                        </div>
                                        <span asp-validation-for="FirstName" class="text-danger"></span>
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label">Last Name</label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="bi bi-person-vcard"></i></span>
                                            <input asp-for="LastName" class="form-control" required />
                                        </div>
                                        <span asp-validation-for="LastName" class="text-danger"></span>
                                    </div>

                                    <div class="col-12">
                                        <label class="form-label">Email Address</label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="bi bi-envelope-at"></i></span>
                                            <input asp-for="Email" class="form-control" type="email" required />
                                        </div>
                                        <span asp-validation-for="Email" class="text-danger"></span>
                                    </div>

                                    <div class="col-md-7">
                                        <label class="form-label">Mobile Number</label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                            <input asp-for="MobileNumber" class="form-control" required />
                                        </div>
                                        <span asp-validation-for="MobileNumber" class="text-danger"></span>
                                    </div>

                                    <div class="col-md-5">
                                        <label class="form-label">Status</label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="bi bi-activity"></i></span>
                                            <select asp-for="EnrolmentStatus" class="form-select fw-bold">
                                                <option value="Active">Active</option>
                                                <option value="Inactive">Inactive</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <!-- Action Footer -->
                                <div class="mt-5 pt-4 border-top d-flex gap-3 align-items-center">
                                    <button type="submit" class="btn btn-primary btn-save shadow">
                                        <i class="bi bi-cloud-check me-2"></i> Save Changes
                                    </button>
                                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <div class="text-center mt-4">
                    <small class="text-muted">
                        Authorized Update by Staff: <strong>@User.Identity?.Name</strong>
                    </small>
                </div>
            </div>
        </div>
    </main>

    <!-- Professional Scripts for Validation -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>