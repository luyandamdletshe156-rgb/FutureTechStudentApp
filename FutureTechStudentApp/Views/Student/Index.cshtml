@model IEnumerable<FutureTechStudentApp.Models.Student>

@{
    Layout = null;
    ViewData["Title"] = "Admin Dashboard | FutureTech";

    int totalStudents = ViewBag.TotalCount ?? 0;
    int activeStudents = ViewBag.ActiveCount ?? 0;
    int inactiveStudents = totalStudents - activeStudents;

    string staffName = User.Identity?.Name ?? "Admin User";
    string staffNumber = User.FindFirst("StaffNumber")?.Value ?? "Admin";
    string department = User.FindFirst("Department")?.Value ?? "Management";
    string initials = string.Concat(staffName.Where(c => char.IsUpper(c)));
    if (string.IsNullOrEmpty(initials)) { initials = "AD"; }

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = (ViewBag.TotalPages ?? 1) == 0 ? 1 : ViewBag.TotalPages;

    bool isAdmin = User.IsInRole("Admin");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(rgba(255, 255, 255, 0.75), rgba(255, 255, 255, 0.75)), url('https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=1920&q=80') no-repeat center center fixed;
            background-size: cover;
            color: #2d3436;
            min-height: 100vh;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.65);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.05);
            border-radius: 1.5rem;
        }

        .navbar-glass {
            background: rgba(255, 255, 255, 0.8) !important;
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        }

        .nav-brand-text {
            font-weight: 800;
            color: #0d6efd !important;
            letter-spacing: -0.5px;
        }

        .staff-avatar {
            width: 38px;
            height: 38px;
            background: #0d6efd;
            color: white;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.85rem;
        }

        .pulse-live {
            width: 8px;
            height: 8px;
            background: #00b894;
            border-radius: 50%;
            display: inline-block;
            margin-right: 8px;
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(0, 184, 148, 0.7); }
            70% { box-shadow: 0 0 0 10px rgba(0, 184, 148, 0); }
            100% { box-shadow: 0 0 0 0 rgba(0, 184, 148, 0); }
        }

        .table thead th {
            background: rgba(0, 0, 0, 0.02);
            color: #0d6efd;
            border: none;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 15px;
        }

        .student-row:hover {
            background: rgba(255, 255, 255, 0.8) !important;
        }

        .student-img {
            width: 42px;
            height: 42px;
            object-fit: cover;
            border-radius: 50%;
            border: 2px solid white;
            box-shadow: 0 4px 8px rgba(0,0,0,0.05);
        }

        .btn-action-circle {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: 0.2s;
            background: white;
            border: 1px solid #eee;
            text-decoration: none;
        }

        .btn-action-circle:hover {
            background: #0d6efd;
            color: white;
            transform: scale(1.1);
        }

        .pagination .page-link {
            border: none;
            background: transparent;
            color: #2d3436;
            font-weight: 600;
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-light navbar-glass sticky-top py-2">
        <div class="container">
            <a class="navbar-brand nav-brand-text" asp-controller="Student" asp-action="Index">
                <i class="bi bi-cpu-fill"></i> FUTURETECH <span class="text-dark fw-light">Portal</span>
            </a>
            <div class="ms-auto d-flex align-items-center">
                <div class="me-3 text-end d-none d-md-block">
                    <span class="fw-bold d-block small">@staffName</span>
                    <small class="text-primary fw-bold" style="font-size: 0.7rem;">ID: @staffNumber • @department</small>
                </div>
                <div class="staff-avatar me-3">@initials</div>
                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-bold">Logout</button>
                </form>
            </div>
        </div>
    </nav>

    <main class="container py-5">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success border-0 shadow-sm glass-panel mb-4">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            </div>
        }

        <div class="row mb-5 align-items-center">
            <div class="col-md-6">
                <div class="d-flex align-items-center mb-1">
                    <span class="pulse-live"></span>
                    <small class="text-uppercase fw-bold text-muted" style="font-size: 0.65rem;">Cloud Active</small>
                </div>
                <h2 class="fw-bold text-dark">Registry Management</h2>
            </div>
            <div class="col-md-6 text-md-end">
                <a asp-action="Create" class="btn btn-primary rounded-pill px-4 py-2 fw-bold shadow">
                    <i class="bi bi-person-plus-fill me-2"></i> Add Student
                </a>
            </div>
        </div>

        <div class="glass-panel overflow-hidden">
            <div class="p-4 border-bottom bg-white bg-opacity-30">
                <form asp-action="Index" method="get" class="row g-2 align-items-center">
                    <div class="col-md-4">
                        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control rounded-pill" placeholder="Search by name or ID...">
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-dark rounded-pill px-4 fw-bold">Filter</button>
                    </div>
                    @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                    {
                        <div class="col-auto">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">Clear</a>
                        </div>
                    }
                </form>
            </div>

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Identity</th>
                            <th>Contact</th>
                            <th class="text-center">Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="bi bi-search fs-1 d-block mb-2"></i>
                                    No students found matching your criteria.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr class="student-row">
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <img src="@item.ProfileImageUrl" onerror="this.src='/images/default-avatar.png'" class="student-img me-3">
                                            <div>
                                                <div class="fw-bold text-dark">@item.FirstName @item.LastName</div>
                                                <small class="text-muted">UID: @item.Id</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="small text-muted">@item.Email</td>
                                    <td class="text-center">
                                        <span class="badge @(item.EnrolmentStatus == "Active" ? "bg-success" : "bg-secondary")">@item.EnrolmentStatus</span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action-circle text-primary me-1" title="Edit Student">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        <form asp-action="SoftDelete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure? This will mark the student as Inactive.');">
                                            <button type="submit" class="btn-action-circle text-warning border-0 bg-transparent" title="Mark Inactive">
                                                <i class="bi bi-person-dash"></i>
                                            </button>
                                        </form>

                                        @if (isAdmin)
                                        {
                                            <!-- THE FIX: Removed the onclick attribute to ensure it redirects to the delete confirmation page -->
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action-circle text-danger" title="Permanent Delete">
                                                <i class="bi bi-trash3"></i>
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="p-4 border-top d-flex justify-content-between align-items-center">
                <small class="text-muted fw-bold">Page @currentPage of @totalPages</small>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-searchString="@ViewData["CurrentFilter"]">Prev</a>
                        </li>
                        <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-searchString="@ViewData["CurrentFilter"]">Next</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </main>
</body>
</html>