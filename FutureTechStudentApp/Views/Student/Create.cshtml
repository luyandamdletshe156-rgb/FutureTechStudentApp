@model FutureTechStudentApp.Models.Student

@{
    Layout = null;
    ViewData["Title"] = "Register Student | FutureTech";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <!-- Professional Assets -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0.7)), url('https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=1920&q=80') no-repeat center center fixed;
            background-size: cover;
            color: #2d3436;
            min-height: 100vh;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.05);
            border-radius: 1.5rem;
            padding: 40px;
        }

        .navbar-glass {
            background: rgba(255, 255, 255, 0.8) !important;
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
            padding: 15px 0;
        }

        .form-section-title {
            font-size: 0.85rem;
            font-weight: 700;
            color: #0d6efd;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
        }

            .form-section-title::after {
                content: "";
                flex: 1;
                height: 1px;
                background: rgba(13, 110, 253, 0.1);
                margin-left: 15px;
            }

        .form-label {
            font-weight: 600;
            font-size: 0.85rem;
            color: #495057;
        }

        .input-group-text {
            background: white;
            border-right: none;
            color: #adb5bd;
            border-radius: 12px 0 0 12px;
        }

        .form-control, .form-select {
            border-left: none;
            border-radius: 0 12px 12px 0;
            padding: 12px;
            border-color: #dee2e6;
        }

        /* Error Message Styling */
        .text-danger {
            font-size: 0.75rem;
            font-weight: 600;
            margin-top: 5px;
            display: block;
        }

        .preview-container {
            width: 100px;
            height: 100px;
            border-radius: 15px;
            overflow: hidden;
            border: 2px solid white;
            box-shadow: 0 5px 15px rgba(0,0,0,0.08);
            margin: 0 auto 15px;
            display: none; /* Hidden until image selected */
        }

        #imgPreview {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .upload-zone {
            background: rgba(255, 255, 255, 0.5);
            border: 2px dashed #dee2e6;
            border-radius: 15px;
            padding: 25px;
            transition: 0.3s;
            text-align: center;
        }

            .upload-zone:hover {
                border-color: #0d6efd;
                background: rgba(13, 110, 253, 0.02);
            }

        .btn-save {
            background: #0d6efd;
            border: none;
            padding: 12px 40px;
            font-weight: 700;
            border-radius: 50px;
            box-shadow: 0 8px 15px rgba(13, 110, 253, 0.2);
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-light navbar-glass sticky-top mb-5">
        <div class="container">
            <a asp-action="Index" class="text-decoration-none fw-bold text-dark hover-blue">
                <i class="bi bi-arrow-left me-2"></i> Back to Records
            </a>
            <span class="navbar-brand ms-auto fw-bold text-primary" style="font-size: 1.1rem;">
                <i class="bi bi-cpu-fill me-1"></i> FUTURETECH <span class="text-dark fw-light">Staff</span>
            </span>
        </div>
    </nav>

    <main class="container pb-5">
        <div class="row justify-content-center">
            <div class="col-lg-9 col-xl-8">

                <div class="glass-panel">
                    <div class="mb-5 text-center">
                        <h2 class="fw-bold text-dark">Add New Student</h2>
                        <p class="text-muted">Fill in the institutional record for the cloud database.</p>
                    </div>

                    <form asp-action="Create" enctype="multipart/form-data" id="studentForm">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-4"></div>

                        <div class="form-section-title"><i class="bi bi-person-fill me-2"></i> Student Details</div>

                        <div class="row g-4 mb-5">
                            <div class="col-md-6">
                                <label class="form-label">First Name</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                                    <input asp-for="FirstName" class="form-control" placeholder="e.g., John" required />
                                </div>
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Last Name</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-person-vcard"></i></span>
                                    <input asp-for="LastName" class="form-control" placeholder="e.g., Doe" required />
                                </div>
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>

                            <div class="col-md-7">
                                <label class="form-label">Institutional Email</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-envelope-at"></i></span>
                                    <input asp-for="Email" class="form-control" type="email" placeholder="student@futuretech.ac.za" required />
                                </div>
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <div class="col-md-5">
                                <label class="form-label">Mobile Number</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                    <input asp-for="MobileNumber" class="form-control" placeholder="012 345 6789" required />
                                </div>
                                <span asp-validation-for="MobileNumber" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-section-title"><i class="bi bi-cloud-arrow-up-fill me-2"></i> Cloud Assets</div>

                        <div class="row g-4 mb-4">
                            <div class="col-12">
                                <div class="upload-zone">
                                    <div class="preview-container" id="previewBox">
                                        <img id="imgPreview" src="#" alt="Preview" />
                                    </div>
                                    <i class="bi bi-camera text-primary fs-3 mb-2 d-block" id="cameraIcon"></i>
                                    <p class="fw-bold mb-1">Upload Photo</p>
                                    <p class="text-muted small mb-3">JPEG or PNG (Max 2MB)</p>
                                    <input type="file" name="profilePicture" id="fileInput" class="form-control bg-white" accept="image/*" required />
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Current Enrolment Status</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-check2-square"></i></span>
                                    <select asp-for="EnrolmentStatus" class="form-select">
                                        <option value="Active">Active Student</option>
                                        <option value="Inactive">Inactive / Suspended</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-3 mt-5 pt-4 border-top">
                            <a asp-action="Index" class="btn btn-light rounded-pill px-4">Cancel</a>
                            <button type="submit" class="btn btn-primary btn-save shadow">
                                <i class="bi bi-cloud-plus me-2"></i> Sync to Azure
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>

    <!-- Scripts for Image Preview & Validation -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // Logic for Image Preview
        document.getElementById('fileInput').onchange = evt => {
            const [file] = document.getElementById('fileInput').files
            if (file) {
                document.getElementById('imgPreview').src = URL.createObjectURL(file);
                document.getElementById('previewBox').style.display = 'block';
                document.getElementById('cameraIcon').style.display = 'none';
            }
        }
    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>